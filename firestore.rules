rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tiap user cuma boleh baca/tulis dokumen datanya sendiri, yang ID-nya
    // sama persis dengan uid Firebase Auth mereka.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
